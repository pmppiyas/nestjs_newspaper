model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  newsId String

  @@map("comments")
}
