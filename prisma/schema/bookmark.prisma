model Bookmark {
  id String @id @default(cuid())

  note   String?
  user   User    @relation(fields: [userId], references: [id])
  userId String

  news   News   @relation(fields: [newsId], references: [id])
  newsId String

  createdAt DateTime @default(now())

  @@unique([userId, newsId])
  @@map("bookmarks")
}
